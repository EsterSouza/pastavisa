generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Pasta {
  id                       String   @id @default(cuid())
  status                   String   @default("rascunho")
  criadaEm                 DateTime @default(now())

  clienteNomeFantasia      String?
  clienteRazaoSocial       String?
  clienteCnpj              String?
  clienteEndereco          String?
  clienteCidade            String?
  clienteEstado            String?
  clienteEstadoExtenso     String?
  clienteTelefone          String?
  clienteEmail             String?
  clienteHorario           String?
  clienteProprietarioNome  String?
  clienteRtNome            String?
  clienteRtProfissao       String?
  clienteRtConselho        String?
  clienteResponsaveisTecnicos String?
  clienteLogoPath          String?
  clienteLogoBgHex         String?
  clienteEstrutura         String?
  clienteMemorialDescritivoMbp String?
  clienteServicos          String?
  clienteFuncionarios      String?
  clienteEquipamentos      String?
  clienteProdutosInsumos   String?
  clienteTerceirizados     String?
  clienteColetaRazao       String?
  clienteColetaCnpj        String?
  clienteResiduosA         String?
  clienteResiduosD         String?
  clienteResiduosE         String?
  clienteInfoAdicionais    String?
  docElaborador            String?
  docMesExtenso            String?
  docAno                   String?

  formsPdfPath             String?
  documentosElaboracaoPath String?
  legislacaoIds            String?

  documentos               DocumentoGerado[]
  documentosUpload         DocumentoUpload[]
}

model DocumentoGerado {
  id              String    @id @default(cuid())
  pastaId         String
  pasta           Pasta     @relation(fields: [pastaId], references: [id], onDelete: Cascade)
  templateId      String?
  template        Template? @relation(fields: [templateId], references: [id])
  nomeArquivo     String
  outputPath      String?
  status          String    @default("pendente")
  tokensUsados    Int?
  mensagemErro    String?
  avisoRtNoCorpo  Boolean   @default(false)
  logoSubstituida Boolean   @default(false)
  equipamentosSelecionados String?
  criadoEm        DateTime  @default(now())
  versoes         DocumentoVersao[]
}

model DocumentoVersao {
  id              String           @id @default(cuid())
  documentoId     String
  documento       DocumentoGerado @relation(fields: [documentoId], references: [id], onDelete: Cascade)
  outputPath      String
  tokensUsados    Int?
  avisoRtNoCorpo  Boolean          @default(false)
  logoSubstituida Boolean          @default(false)
  criadaEm        DateTime         @default(now())

  @@index([documentoId, criadaEm])
}

model DocumentoUpload {
  id            String    @id @default(cuid())
  pastaId       String
  pasta         Pasta     @relation(fields: [pastaId], references: [id], onDelete: Cascade)
  nomeArquivo   String
  uploadPath    String
  outputPath    String?
  status        String    @default("pendente")
  mensagemErro  String?
  criadoEm      DateTime  @default(now())
  versoes       DocumentoUploadVersao[]
}

model DocumentoUploadVersao {
  id                String          @id @default(cuid())
  documentoUploadId String
  documentoUpload   DocumentoUpload @relation(fields: [documentoUploadId], references: [id], onDelete: Cascade)
  outputPath        String
  substituicoes     String?
  criadaEm          DateTime        @default(now())

  @@index([documentoUploadId, criadaEm])
}

model Template {
  id             String            @id @default(cuid())
  nome           String
  tipo           String
  padraoHeader   String
  processingType String            @default("LIGHT_HAIKU")
  arquivoPath    String
  ativo          Boolean           @default(true)
  criadoEm       DateTime          @default(now())
  documentos     DocumentoGerado[]
  versoes        TemplateVersao[]
}

model TemplateVersao {
  id             String   @id @default(cuid())
  templateId     String
  template       Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  nome           String
  tipo           String
  padraoHeader   String
  processingType String
  arquivoPath    String
  motivo         String?
  criadaEm       DateTime @default(now())

  @@index([templateId, criadaEm])
}

model Legislacao {
  id             String  @id @default(cuid())
  estadoUf       String
  municipio      String?
  tipo           String
  titulo         String
  referenciaAbnt String
  destaqueAbnt   String?
  chaveReferencia String? @unique
  ativo          Boolean @default(true)
}

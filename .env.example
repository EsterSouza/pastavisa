ANTHROPIC_API_KEY=

# Banco Supabase/Postgres.
# Use uma connection string Postgres do Supabase.
DATABASE_URL=

# Supabase Storage. SUPABASE_SERVICE_ROLE_KEY fica apenas no servidor.
FILE_STORAGE_DRIVER=local
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=pasta-visa

# Pasta local com os .docx de template, usada pelo script
# scripts/sync-local-templates-to-supabase.js. Opcional: se vazio, o script
# tenta um caminho padrao e depois a pasta TODOS_OS_TEMPLATES_PastaVISA no projeto.
TEMPLATE_SOURCE_DIR=

# Protecao temporaria em producao antes do login completo.
APP_BASIC_AUTH_USER=
APP_BASIC_AUTH_PASSWORD=
